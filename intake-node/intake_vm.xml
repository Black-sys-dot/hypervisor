<domain type='kvm'>
  <name>rangda-interactive-intake</name>
  <memory unit='KiB'>4194304</memory>
  <vcpu placement='static'>4</vcpu>
  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
    <boot dev='hd'/>
    <boot dev='cdrom'/>
  </os>
  <features>
    <acpi/>
    <apic/>
  </features>
  <cpu mode='host-passthrough' check='none'/>
  
  <!-- REQUIRED FOR VIRTIO-FS MOUNTS -->
  <memoryBacking>
    <access mode='shared'/>
  </memoryBacking>

  <devices>
    <emulator>/usr/bin/qemu-system-x86_64</emulator>
    
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='/var/lib/libvirt/images/rangda-intake-node.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    
    <interface type='network'>
      <source network='default'/>
      <model type='e1000'/>
    </interface>

    <!-- Trusted Vault virtio-fs Mount -->
    <filesystem type='mount' accessmode='passthrough'>
      <driver type='virtiofs'/>
      <source dir='/var/lib/libvirt/images/trusted'/>
      <target dir='vault_share'/>
    </filesystem>

    <!-- Quarantine virtio-fs Mount -->
    <filesystem type='mount' accessmode='passthrough'>
      <driver type='virtiofs'/>
      <source dir='/var/lib/libvirt/quarantine'/>
      <target dir='quarantine_share'/>
    </filesystem>

    <!-- SPICE Graphics and Agent Integration (Clipboard & Resizing) -->
    <graphics type='spice' autoport='yes' listen='127.0.0.1'>
      <listen type='address' address='127.0.0.1'/>
      <clipboard copypaste='yes'/>
      <mouse mode='client'/>
    </graphics>
    
    <video>
      <model type='qxl' ram='65536' vram='65536' vgamem='16384' heads='1'/>
    </video>

    <!-- QEMU Guest Agent Channel -->
    <channel type='unix'>
      <target type='virtio' name='org.qemu.guest_agent.0'/>
    </channel>

    <!-- SPICE vdagent Channel (Clipboard/Mouse) -->
    <channel type='spicevmc'>
      <target type='virtio' name='com.redhat.spice.0'/>
    </channel>

    <input type='tablet' bus='usb'/>
    <input type='mouse' bus='ps2'/>
  </devices>
</domain>
